# ConfidentialFlow — root environment variables example
# Copy to artifacts/app/.env for the frontend

# Wallet / network
VITE_SEPOLIA_RPC_URL=https://rpc.sepolia.org

# WalletConnect v3 project ID (get one free at https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Contract addresses — fill in after running: cd contracts && npm run deploy:sepolia
VITE_CUSDT_ADDRESS=
VITE_GATE_ADDRESS=
VITE_VAULT_ADDRESS=
VITE_VESTING_ADDRESS=
VITE_FLOW_REGISTRY_ADDRESS=
