# ConfidentialFlow contracts — environment variables
# Copy to contracts/.env

# Sepolia RPC endpoint (Infura, Alchemy, or public)
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Deployer private key (0x-prefixed, keep secret)
DEPLOYER_PRIVATE_KEY=0x

# cUSDT ERC-7984 token address on Sepolia (Zama-deployed)
# Check https://docs.zama.ai for the latest address
CUSDT_ADDRESS=

# Filled in after deploy.ts runs:
GATE_ADDRESS=
VAULT_ADDRESS=
VESTING_ADDRESS=
FLOW_REGISTRY_ADDRESS=
